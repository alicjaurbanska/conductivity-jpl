    print(f"  {name:12s} native range: T {tr[0]:.1f}-{tr[1]:.1f} K, I_eff {ir[0]:.4f}-{ir[1]:.4f} mol/kg")


# ==========================================
# 9. PHASE 1 FLATNESS AUDIT (runs only in WALDEN mode)
# How much T-variation did Walden move out of the spline?
# Ratio << 1 means the reparameterization is doing its job and
# T-extrapolation of W is defensible.
# ==========================================
if WALDEN:
    print("\nWalden flatness audit (at each ion's median I_eff):")
    print(f"{'ion':14s} {'alpha':>6s} {'lam spread/mean':>16s} {'W spread/mean':>14s} {'ratio':>7s}")
    for name, (spl, tr, ir, ion_df) in ION_SPLINES.items():
        T = np.linspace(tr[0], tr[1], 80)
        I_mid = np.full_like(T, np.median(ion_df['I'].values))
        lam = spl.ev_or_nan(T, I_mid)
        Wv = spl.W(T, I_mid)
        ok = ~np.isnan(lam)
        sp_lam = (np.nanmax(lam[ok]) - np.nanmin(lam[ok])) / np.nanmean(lam[ok])
        sp_W = (np.nanmax(Wv[ok]) - np.nanmin(Wv[ok])) / np.nanmean(Wv[ok])
        print(f"{name:14s} {spl.alpha:6.3f} {sp_lam:16.3f} {sp_W:14.3f} {sp_W/sp_lam:7.3f}")

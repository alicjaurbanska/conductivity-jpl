# 0.2 WATER VISCOSITY (IAPWS-95 + IAPWS 2008, cached per pressure)
# ==========================================

class WaterViscosity:
    """eta_water(T, P) in mPa s from the iapws package (IAPWS-95 EOS +
    IAPWS 2008 viscosity). Direct IAPWS calls are slow, so a 1D cubic
    spline of eta(T) is built once per requested pressure and cached.
    Below 273.15 K iapws returns the metastable (supercooled) liquid
    branch with an 'extrapolated values' warning - that is the branch
    we want for subzero brines. Accuracy degrades below ~250 K; the
    table is clipped there and queries outside it raise."""

    T_MIN, T_MAX, N_GRID = 250.15, 372.15, 245

    def __init__(self):
        self._cache = {}  # P_MPa (rounded) -> (spline, dspline, T_lo, T_hi)

    def _key(self, P_MPa):
        return round(float(P_MPa), 4)

    def _build(self, P_MPa):
        try:
            from iapws import IAPWS95
        except ImportError:
            raise ImportError("WALDEN mode needs the iapws package: run `!pip install iapws` "
                               "in a cell at the top of the notebook, then rerun Cell 1.")
        T_grid, eta_grid = [], []
        with warnings.catch_warnings():
            warnings.simplefilter('ignore')  # expected: metastable extrapolation notice
            for T in np.linspace(self.T_MIN, self.T_MAX, self.N_GRID):
                try:
                    w = IAPWS95(T=float(T), P=float(P_MPa))
                    mu = getattr(w, 'mu', None)
                    if mu is not None and np.isfinite(mu) and mu > 0:
                        T_grid.append(T)
                        eta_grid.append(mu * 1000.0)  # Pa s -> mPa s
                except Exception:
                    continue  # skip states iapws cannot converge (deep supercooling)
        if len(T_grid) < 20:
            raise RuntimeError(f'WaterViscosity: IAPWS table build failed at P={P_MPa} MPa '
                                f'({len(T_grid)} usable points).')
        T_grid = np.asarray(T_grid)
        spl = UnivariateSpline(T_grid, np.asarray(eta_grid), k=3, s=0)
        self._cache[self._key(P_MPa)] = (spl, spl.derivative(), T_grid.min(), T_grid.max())
        print(f'  WaterViscosity: built eta(T) table at P={P_MPa} MPa, '
              f'valid {T_grid.min():.1f}-{T_grid.max():.1f} K.')

    def _get(self, P_MPa):
        k = self._key(P_MPa)
        if k not in self._cache:
            self._build(P_MPa)
        return self._cache[k]

    def eta(self, T_K, P_MPa):
        spl, _, lo, hi = self._get(P_MPa)
        T_K = np.atleast_1d(np.asarray(T_K, dtype=float))
        if np.any((T_K < lo) | (T_K > hi)):
            raise ValueError(f'WaterViscosity: T outside tabulated {lo:.1f}-{hi:.1f} K '
                              f'at P={P_MPa} MPa.')
        return spl(T_K)

    def deta_dT(self, T_K, P_MPa):
        _, dspl, lo, hi = self._get(P_MPa)
        T_K = np.atleast_1d(np.asarray(T_K, dtype=float))
        return dspl(np.clip(T_K, lo, hi))


VISC = WaterViscosity()


# ==========================================
# 0.3 SPLINE WRAPPER (cubic B-spline, grid-aware, Walden-aware)
# ==========================================

class IonSpline:
    """Cubic (kx=ky=3) tensor-product B-spline over (T, sqrt(I_eff)) with a
    lambda-space interface (.ev, .ev_or_nan, .dT, .dI_val, .d2I_val) and
    built-in validation of thermodynamic limits.
    With WALDEN=True the FITTED quantity is W = lambda * eta_water(T, P_ref);
    evaluation divides eta back out at the requested (T, P):
        lambda(T, P, I) = W_spline(T, sqrt(I)) / eta_water(T, P).
    NOTE: the I axis is EFFECTIVE (speciated) ionic strength, and speciation
    is ambient-pressure chemistry; P moves only the mobility channel."""

    def __init__(self, t, I, lambda_val, label, s=None, kx=3, ky=3, grid_decimals=6,
                 P_ref_MPa=REFERENCE_PRESSURE_MPA):
        self.label = label
        self.P_ref = P_ref_MPa
        t = np.asarray(t, dtype=float)
        I = np.asarray(I, dtype=float)
        lambda_val = np.asarray(lambda_val, dtype=float)

        # ---- Walden transform of the fit target ----
        # Fractional Walden: W = lambda * eta^alpha, with alpha fitted per
        # ion from the TRAINING points (never validation data) so that the
        # W surface is as T-flat as the data allow. alpha = 1 recovers the
        # strict Walden rule; aqueous ions typically show alpha ~ 0.85-0.95.
        if WALDEN:
            self.alpha = self._fit_alpha(t, I, lambda_val, self.P_ref) \
                if WALDEN_ALPHA_FIT else 1.0
            z_fit = lambda_val * VISC.eta(t, self.P_ref) ** self.alpha
        else:
            self.alpha = 1.0
            z_fit = lambda_val

        n_t, n_I = len(np.unique(t)), len(np.unique(I))
        if n_t < kx + 1 or n_I < ky + 1:
            raise ValueError(
                f"{label}: a bidegree-{kx} spline needs >= {kx + 1} distinct T values "
                f"and >= {ky + 1} distinct I values; got {n_t} T levels, {n_I} I levels."
            )

        m = len(t)
        s_used = (m - np.sqrt(2 * m)) if s is None else s
        self.s_used = s_used

        grid = self._try_grid(t, I, z_fit, grid_decimals, kx=kx, ky=ky)
        try:
            if grid is not None:
                Tg, Ig, Z, gtag = grid
                X_g = np.sqrt(Ig) if SQRT_I else Ig
                self._spline = RectBivariateSpline(Tg, X_g, Z, kx=kx, ky=ky, s=s_used)
                self.method = gtag
            else:
                X_scatter = np.sqrt(I) if SQRT_I else I
                self._spline = SmoothBivariateSpline(t, X_scatter, z_fit, kx=kx, ky=ky, s=s_used)
                self.method = 'scattered (SmoothBivariateSpline)'
        except Exception as e:
            raise RuntimeError(
                f"{label}: bicubic spline fit failed (s={s_used}, method attempt="
                f"{'grid' if grid is not None else 'scattered'}): {e}. "
                f"Try raising s, or check for near-duplicate/near-collinear (T, I) points."
            )

        self.method += f' [Walden a={self.alpha:.3f}]' if WALDEN else ' [raw lambda]'

        # Build the hull in the same coordinate space used by the spline fit
        self._hull = Delaunay(np.column_stack([t, self._x(I)]))
        self.t_range = (float(t.min()), float(t.max()))
        self.I_range = (float(I.min()), float(I.max()))

        # Post-fit physical assumption check (always in LAMBDA space)
        self.validate_physics()

    @staticmethod
    def _try_grid(t, I, zval, decimals, kx=3, ky=3, n_common=None):
        """Place (t, I, z) data onto a rectangle for RectBivariateSpline.
        Returns (Tg, Ig, Z, tag) with Ig in RAW ionic strength (caller
        applies the sqrt transform), or None -> scattered fallback.

        Stage 1 (exact pivot): fires only if I is literally identical
        across T levels after rounding - true pre-speciation, false after
        (I_eff drifts with T even for non-pairing salts).

        Stage 2 (regrid): per T level, fit a 1D INTERPOLATING spline of z
        against the fit coordinate x (sqrt(I) or I) - zero smoothing, since
        smoothing happens once in the final 2D fit - then resample every
        level onto a common x grid restricted to the INTERSECTION of all
        levels' native ranges, so no resampled value extrapolates its own
        level. Common columns are placed at rank-wise quantiles of the
        levels' own x values (preserves the data's natural spacing; on
        smooth-in-x surfaces this matches linspace, and it is safer if
        spacing ever becomes irregular). Levels with < ky+1 usable points
        are dropped. NOTE: hull regions outside the common window are
        CLAMPED by FITPACK to the boundary column (constant continuation),
        not extrapolated; the coverage printout quantifies that margin."""
        t_r = np.round(np.asarray(t, dtype=float), decimals)
        I = np.asarray(I, dtype=float)
        z = np.asarray(zval, dtype=float)

        # ---- Stage 1: exact pivot ----
        df = pd.DataFrame({'t': t_r, 'I': np.round(I, decimals), 'z': z})
        df = df.drop_duplicates(subset=['t', 'I'])
        if len(df) >= 2:
            piv = df.pivot(index='t', columns='I', values='z')
            if (not piv.isna().any().any()) and piv.shape[0] >= kx + 1 and piv.shape[1] >= ky + 1:
                return (piv.index.values, piv.columns.values, piv.values,
                        'grid (RectBivariateSpline)')

        # ---- Stage 2: per-level resampling onto a common x axis ----
        x = np.sqrt(I) if SQRT_I else I
        levels, dropped_sparse = [], 0
        for tv in np.unique(t_r):
            msk = t_r == tv
            xs, zs = x[msk], z[msk]
            order = np.argsort(xs)
            xs, zs = xs[order], zs[order]
            keep = np.concatenate([[True], np.diff(xs) > 1e-10])  # strictly increasing
            xs, zs = xs[keep], zs[keep]
            if len(xs) >= ky + 1:
                levels.append((tv, xs, zs))
            else:
                dropped_sparse += 1
        if len(levels) < kx + 1:
            print(f"    _try_grid: only {len(levels)} T-levels with >= {ky + 1} distinct I "
                  f"points ({dropped_sparse} too sparse); need >= {kx + 1}. Scattered fallback.")
            return None

        x_lo = max(xs.min() for _, xs, _ in levels)
        x_hi = min(xs.max() for _, xs, _ in levels)
        if not (np.isfinite(x_lo) and np.isfinite(x_hi)) or x_hi <= x_lo:
            print("    _try_grid: intersection of per-level I-ranges is empty. Scattered fallback.")
            return None

        n_pts = n_common or max(int(np.median([len(xs) for _, xs, _ in levels])), ky + 1)
        qs = np.linspace(0.0, 1.0, n_pts)
        x_common = np.array([np.median([np.quantile(xs, q) for _, xs, _ in levels]) for q in qs])
        x_common = np.unique(np.clip(x_common, x_lo, x_hi))
        if len(x_common) < ky + 1:  # degenerate quantiles -> uniform window
            x_common = np.linspace(x_lo, x_hi, max(n_pts, ky + 1))

        T_grid = np.array([tv for tv, _, _ in levels])
        Z = np.empty((len(levels), len(x_common)))
        for i, (tv, xs, zs) in enumerate(levels):
            Z[i, :] = UnivariateSpline(xs, zs, k=ky, s=0)(x_common)

        cov = (x_hi - x_lo) / (x.max() - x.min()) if x.max() > x.min() else 1.0
        print(f"    _try_grid: regridded {len(levels)}/{len(levels) + dropped_sparse} T-levels x "
              f"{len(x_common)} I-columns; common window covers {cov:.1%} of the sqrt(I) span "
              f"(outside it FITPACK clamps to the boundary column).")
        I_common = x_common ** 2 if SQRT_I else x_common
        return T_grid, I_common, Z, 'regridded (RectBivariateSpline)'

    @staticmethod
    def _fit_alpha(t, I, lam, P_ref):
        """Fractional Walden exponent from training data: regress
        log(lambda) = c0 + c1*sqrt(I) + c2*I - alpha*log(eta).
        The sqrt(I)/I terms absorb ionic-strength structure so alpha is
        estimated from the T direction (eta varies ~5x over 278-363 K).
        Clipped to [0.5, 1.2] as a sanity band."""
        eta = VISC.eta(t, P_ref)
        s = np.sqrt(np.asarray(I, dtype=float))
        A = np.column_stack([np.ones_like(s), s, s * s, np.log(eta)])
        coef, *_ = np.linalg.lstsq(A, np.log(np.asarray(lam, dtype=float)), rcond=None)
        return float(np.clip(-coef[3], 0.5, 1.2))

    def _in_hull(self, t_query, I_query):
        return self._hull.find_simplex(np.column_stack([t_query, self._x(I_query)])) >= 0

    def _x(self, I):
        return np.sqrt(I) if SQRT_I else np.asarray(I, dtype=float)

    def _eta(self, t_query, P_MPa):
        return VISC.eta(t_query, self.P_ref if P_MPa is None else P_MPa)

    # ---- W-space accessor (diagnostics / flatness checks) ----
    def W(self, t_query, I_query):
        """Fitted surface value: Walden product if WALDEN else lambda."""
        t_query, I_query = np.atleast_1d(t_query), np.atleast_1d(I_query)
        z = self._spline.ev(t_query, self._x(I_query))
        return np.where(self._in_hull(t_query, I_query), z, np.nan)

    # ---- lambda-space interface (same signatures + optional P) ----
    def ev_or_nan(self, t_query, I_query, P_MPa=None):
        t_query, I_query = np.atleast_1d(t_query), np.atleast_1d(I_query)
        z = self._spline.ev(t_query, self._x(I_query))
        if WALDEN:
            z = z / self._eta(t_query, P_MPa) ** self.alpha
        return np.where(self._in_hull(t_query, I_query), z, np.nan)

    def ev(self, t_query, I_query, P_MPa=None):
        result = self.ev_or_nan(t_query, I_query, P_MPa)
        if np.any(np.isnan(result)):
            raise ValueError(f"{self.label} spline: query point(s) fall outside the convex hull.")
        return result if result.size > 1 else result.item()

    def dT(self, t_query, I_query, P_MPa=None):
        """d lambda / dT. Under fractional Walden: lambda = W/eta^alpha, so
        dlambda/dT = dW/dT / eta^alpha - alpha * lambda * (deta/dT) / eta."""
        t_query, I_query = np.atleast_1d(t_query), np.atleast_1d(I_query)
        dW = self._spline.ev(t_query, self._x(I_query), dx=1, dy=0)
        if WALDEN:
            P = self.P_ref if P_MPa is None else P_MPa
            eta = self._eta(t_query, P_MPa)
            eta_a = eta ** self.alpha
            lam = self._spline.ev(t_query, self._x(I_query)) / eta_a
            val = dW / eta_a - self.alpha * lam * VISC.deta_dT(t_query, P) / eta
        else:
            val = dW
        return np.where(self._in_hull(t_query, I_query), val, np.nan)

    def dI_val(self, t_query, I_query, P_MPa=None):
        t_query, I_query = np.atleast_1d(t_query), np.atleast_1d(I_query)
        g = self._spline.ev(t_query, self._x(I_query), dx=0, dy=1)
        val = g / (2 * np.sqrt(I_query)) if SQRT_I else g
        if WALDEN:
            val = val / self._eta(t_query, P_MPa) ** self.alpha  # eta independent of I
        return np.where(self._in_hull(t_query, I_query), val, np.nan)

    def d2I_val(self, t_query, I_query, P_MPa=None):
        t_query, I_query = np.atleast_1d(t_query), np.atleast_1d(I_query)
        g1 = self._spline.ev(t_query, self._x(I_query), dx=0, dy=1)
        g2 = self._spline.ev(t_query, self._x(I_query), dx=0, dy=2)
        if SQRT_I:
            u = np.sqrt(I_query)
            val = g2 / (4 * I_query) - g1 / (4 * I_query * u)
        else:
            val = g2
        if WALDEN:
            val = val / self._eta(t_query, P_MPa) ** self.alpha
        return np.where(self._in_hull(t_query, I_query), val, np.nan)

    def validate_physics(self):
        """Sweeps a dense grid over the hull to check thermodynamic rules,
        always in LAMBDA space at P_ref, so the checks keep their physical
        meaning under Walden scaling (dW/dT of either sign is fine and
        expected; only dlambda/dT must be > 0). I is sampled logarithmically
        so the low-I decades are audited as densely as high I."""
        t_vals = np.linspace(self.t_range[0], self.t_range[1], 50)
        I_lo = max(1e-6, self.I_range[0])
        I_vals = np.geomspace(I_lo, self.I_range[1], 50)
        Tg, Ig = np.meshgrid(t_vals, I_vals)
        Tg_flat, Ig_flat = Tg.ravel(), Ig.ravel()

        inside = self._in_hull(Tg_flat, Ig_flat)
        Ti, Ii = Tg_flat[inside], Ig_flat[inside]

        if len(Ti) == 0:
            return

        lam = self.ev_or_nan(Ti, Ii)
        dT = self.dT(Ti, Ii)
        dI = self.dI_val(Ti, Ii)
        d2I = self.d2I_val(Ti, Ii)

        violations = []
        if np.any(lam < 0):
            violations.append(f"{(lam < 0).sum()} points have lam < 0")
        if np.any(dT < 0):
            violations.append(f"{(dT < 0).sum()} points have dT < 0")
        if np.any(dI > 0):
            violations.append(f"{(dI > 0).sum()} points have dI > 0")
        if np.any(d2I < 0):
            violations.append(f"{(d2I < 0).sum()} points have d2I < 0")

        if violations:
            print(f"  [PHYSICS WARNING for {self.label}]: Model boundaries violated inside hull:")
            for v in violations:
                print(f"    - {v}")


# ==========================================
# 0.4 SPECIATION LOOKUP (reads precomputed Reaktoro table)
# ==========================================

# ion name (model convention) -> free-molality column in speciation_table.csv
ION_FREE_COL = {'K': 'm_free_K', 'Cl': 'm_free_Cl', 'Na': 'm_free_Na',
                'Mg': 'm_free_Mg', 'SO4': 'm_free_SO4'}
PAIR_COLS = ['m_pair_KSO4', 'm_pair_NaSO4', 'm_pair_MgSO4']
MERGE_DECIMALS = 6  # rounding for float-safe merge keys


class SpeciationLookup:
    """Interpolates the precomputed speciation table so free-ion molalities
    and effective I are available at arbitrary (T, m) inside each salt's
    speciated coverage. Linear interpolation over (temp_K, molality)."""

    def __init__(self, spec_df):
        self.interp = {}
        for salt, d in spec_df.groupby('Salt'):
            pts = np.column_stack([d['Temperature_C'].values + 273.15,
                                    d['Molality_molkg'].values])
            cols = {}
            for col in list(ION_FREE_COL.values()) + PAIR_COLS + ['I_eff']:
                if col in d.columns:
                    cols[col] = LinearNDInterpolator(pts, d[col].values)
            self.interp[salt] = cols

    def get(self, salt, T_K, molality, col):
        f = self.interp[salt].get(col)
        if f is None:
            return np.full(np.atleast_1d(T_K).shape, np.nan)
        return f(np.atleast_1d(T_K), np.atleast_1d(molality))


# ==========================================
# 0.5 ION CONDUCTIVITY MODEL
# ==========================================

class IonConductivityModel:
    SALT_STOICHIOMETRY = {
        'KCl':    {'K': 1, 'Cl': 1},
        'NaCl':   {'Na': 1, 'Cl': 1},
        'MgCl2':  {'Mg': 1, 'Cl': 2},
        'Na2SO4': {'Na': 2, 'SO4': 1},
        'K2SO4':  {'K': 2, 'SO4': 1},
        'MgSO4':  {'Mg': 1, 'SO4': 1},
    }

    def __init__(self, speciation=None):
        self.splines = {}
        self.speciation = speciation  # SpeciationLookup

    def add_ion(self, ion_name, spline):
        self.splines[ion_name] = spline
        return spline

    def ion(self, ion_name):
        if ion_name not in self.splines:
            raise KeyError(f"No fitted spline for ion '{ion_name}' yet. "
                            f"Available: {list(self.splines)}")
        return self.splines[ion_name]

    def stoich_for(self, salt_name):
        if salt_name not in self.SALT_STOICHIOMETRY:
            raise ValueError(f"Unknown salt '{salt_name}'. Known salts: {list(self.SALT_STOICHIOMETRY)}")
        return self.SALT_STOICHIOMETRY[salt_name]

    def predict(self, salt_name, T_K, molality, allow_extrapolation_nan=True, P_MPa=None):
        """Speciation-first prediction: kappa = sum over FREE ions of
        m_free_i * lambda_i(T, I_eff). Pair species are treated as
        non-conducting (their conductivity is neglected in this pass).
        P_MPa (optional, WALDEN only) moves the solvent-viscosity channel;
        speciation stays ambient-pressure chemistry for now."""
        stoich = self.stoich_for(salt_name)
        T_K = np.atleast_1d(np.asarray(T_K, dtype=float))
        molality = np.atleast_1d(np.asarray(molality, dtype=float))
        if self.speciation is None:
            raise RuntimeError("predict() requires a SpeciationLookup (speciation_table.csv).")

        I = self.speciation.get(salt_name, T_K, molality, 'I_eff')

        total = np.zeros_like(T_K, dtype=float)
        for ion_name in stoich:
            spline = self.ion(ion_name)
            m_free = self.speciation.get(salt_name, T_K, molality, ION_FREE_COL[ion_name])
            eval_fn = spline.ev_or_nan if allow_extrapolation_nan else spline.ev
            lam = eval_fn(T_K, I, P_MPa)
            total = total + m_free * lam
        # PHASE 4: conducting charged pairs (fixed McCleskey-2012 lambdas)
        if PAIR_CONDUCTION and salt_name in SALT_PAIR_TERMS:
            cols = {}
            for col in SALT_PAIR_TERMS[salt_name]:
                cols[col] = self.speciation.get(salt_name, T_K, molality, col)
            total = total + pair_kappa(cols, T_K, I, list(cols))
        return total if total.size > 1 else total.item()



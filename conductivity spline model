# ==========================================================
# CELL 1 - THE MODEL
#
# Ion pairing correction: all ionic strengths are EFFECTIVE
# (speciated) values and all molalities entering/leaving the
# deconvolution are FREE-ION molalities, both precomputed with
# Reaktoro (phreeqc.dat, ion-association model) on the laptop
# and read here from speciation_table.csv. Pair species
# (KSO4-, NaSO4-, MgSO4) are treated as NON-conducting for this
# first pass; their molalities are carried in the table so they
# can be given their own lambda later.
#
# DUPLICATE-HANDLING FIX (this version): fit_lambda_spline used to do
# d.drop_duplicates(subset=[t_col, I_col]), which silently keeps an
# ARBITRARY first row whenever multiple measurements land at the same
# (T, I_eff) - e.g. replicate measurements from a source like Cortes2026,
# which reports up to 6 replicates per condition. That meant N-1 of N
# replicates were discarded with no record of it happening. It now
# groups by (t_col, I_col) and AVERAGES lambda_col, printing how many
# points were collapsed and the worst replicate spread, so replicate
# data contributes its mean instead of a coin-flip single measurement,
# and a high spread (e.g. instrument drift) is visible rather than hidden.
#
# ==========================================================

import os
import warnings
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from scipy.interpolate import (SmoothBivariateSpline, RectBivariateSpline,
                                LinearNDInterpolator, UnivariateSpline)
from scipy.spatial import Delaunay

FIG_DIR = 'Figures'
os.makedirs(FIG_DIR, exist_ok=True)

SQRT_I = True   # GLOBAL SWITCH: fit splines against sqrt(I) instead of raw I
WALDEN = True   # GLOBAL SWITCH: fit W = lambda * eta_water^alpha.
# Needs `!pip install iapws`.
WALDEN_ALPHA_FIT = True  # PHASE 1.5: fit the fractional Walden exponent alpha
# per ion from TRAINING data (log lambda vs log eta regression
# over 278-363 K). False -> alpha = 1 (strict Walden rule).

MIN_POINTS = 16
REFERENCE_PRESSURE_MPA = 0.1
SPECIATION_FILE = 'speciation_table.csv'  # precomputed with Reaktoro (see speciate_library.py)

PAIR_CONDUCTION = True  # PHASE 4: charged ion pairs (NaSO4-, KSO4-) conduct.
# Their molar conductivities are taken as FIXED EXTERNAL INPUTS from
# McCleskey et al. (2012) Table 1 (Lattey form, T in Celsius), NOT fitted:
#   - NaSO4- contribution is SUBTRACTED from kappa during the Na2SO4 ->
#     SO4 2- deconvolution, so the derived SO4 surface is decontaminated;
#   - pair contributions are ADDED back in predictions for salts whose
#     speciation produces charged pairs (K2SO4, Na2SO4).
# Neutral pairs (MgSO4(aq)) remain non-conducting - that is physics.
# CONSISTENCY CAVEAT: these effective pair lambdas were regressed inside
# McCleskey's WATEQ4F speciation framework; using them with phreeqc.dat
# speciation is slightly inconsistent (expected small flat offset).

MC12_PAIR_COEFFS = {
    #           lam0: (a, b, c)                A: (p, q, r)                 B
    'KSO4':  ((-0.002439, 4.253, 129.7), (-0.01576, 6.210, 146.8), 1.3),
    'NaSO4': ((0.002309, 5.459, 219.2), (0.01454, 5.193, 253.6), 0.5),
}
# speciation-table pair column -> coefficient key
PAIR_LAMBDA_FOR_COL = {'m_pair_KSO4': 'KSO4', 'm_pair_NaSO4': 'NaSO4'}
# salt -> charged-pair columns contributing to its conductivity
SALT_PAIR_TERMS = {'K2SO4': ['m_pair_KSO4'], 'Na2SO4': ['m_pair_NaSO4']}


def mc12_pair_lambda(pair_key, T_K, I):
    """McCleskey et al. (2012) Table 1 molar conductivity for a charged
    ion pair, evaluated at the solution's ionic strength. T in Kelvin in,
    Celsius internally; I is the (effective) ionic strength."""
    (a, b, c), (p, q, r), B = MC12_PAIR_COEFFS[pair_key]
    T_C = np.asarray(T_K, dtype=float) - 273.15
    sqrt_I = np.sqrt(np.asarray(I, dtype=float))
    lam0 = a * T_C**2 + b * T_C + c
    A = p * T_C**2 + q * T_C + r
    return lam0 - A * sqrt_I / (1.0 + B * sqrt_I)


def pair_kappa(source_df_or_cols, T_K, I, pair_cols):
    """Sum of m_pair * lambda_pair over the given pair columns.
    source_df_or_cols: DataFrame with the pair columns, or a dict-like."""
    total = np.zeros_like(np.atleast_1d(np.asarray(T_K, dtype=float)))
    for col in pair_cols:
        key = PAIR_LAMBDA_FOR_COL[col]
        m_pair = np.asarray(source_df_or_cols[col], dtype=float)
        total = total + np.nan_to_num(m_pair) * mc12_pair_lambda(key, T_K, I)
    return total



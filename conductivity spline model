# The working library copy may carry Mahboub MgSO4 conductivities a
# factor of 10 low (values entered in S/m under the mS/cm header).
# Detection: at 20-25 C and 0.3-1.0 mol/kg, MgSO4 conductivity must
# be tens of mS/cm. If the raw values fail that window but exactly
# x10 passes it, the correction is applied to Mahboub MgSO4 rows ONLY
# (the mixture rows are excluded from the model and left untouched).
# If the CSV is fixed at source later, detection passes and nothing
# is changed - no double-correction risk.

def _maybe_fix_mahboub_mgso4_units(df):
    win = ((df['Salt'] == 'MgSO4') & (df['Temperature_C'].between(20.0, 25.0)) &
           (df['Molality_molkg'].between(0.3, 1.0)) & (df['Pressure_MPa'] == 0.1))
    k = df.loc[win, 'Conductivity_mScm'].values
    if len(k) == 0:
        return df
    raw_ok = np.all((k >= 10.0) & (k <= 100.0))
    x10_ok = np.all((10.0 * k >= 10.0) & (10.0 * k <= 100.0))
    if raw_ok:
        return df  # units already correct
    if x10_ok:
        fix = (df['Source'] == 'Mahboub') & (df['Salt'] == 'MgSO4')
        df.loc[fix, 'Conductivity_mScm'] *= 10.0
        print('=' * 70)
        print(f'UNIT AUTO-FIX: {fix.sum()} Mahboub MgSO4 rows multiplied by 10 '
              '(S/m stored under mS/cm header).')
        print('Fix this at source in the library CSV when convenient; this '
              'correction will then detect clean units and do nothing.')
        print('=' * 70)
        return df
    raise ValueError(
        'UNIT AUTO-FIX: MgSO4 values near 25 C fail the physical window both '
        f'raw and x10 (found {np.round(k, 2)} mS/cm). Inspect the library manually.')



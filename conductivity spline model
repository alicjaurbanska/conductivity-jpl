def _assert_units(df):
    # (a) cross-source consistency: Mahboub NaCl at 25 C must agree
    #     with McCleskey NaCl at 25 C after interpolating kappa(m).
    mc = df[(df['Source'] == 'McCleskey2011') & (df['Salt'] == 'NaCl') &
            (df['Temperature_C'] == 25.0)].sort_values('Molality_molkg')
    mh = df[(df['Source'] == 'Mahboub') & (df['Salt'] == 'NaCl') &
            (df['Temperature_C'] == 25.0)]
    if len(mc) >= 3 and len(mh) >= 1:
        inside = mh[(mh['Molality_molkg'] >= mc['Molality_molkg'].min()) &
                    (mh['Molality_molkg'] <= mc['Molality_molkg'].max())]
        if len(inside) >= 1:
            kappa_interp = np.interp(inside['Molality_molkg'].values,
                                      mc['Molality_molkg'].values,
                                      mc['Conductivity_mScm'].values)
            ratio = inside['Conductivity_mScm'].values / kappa_interp
            if np.any((ratio < 0.85) | (ratio > 1.15)):
                raise ValueError(
                    'UNIT GUARD: Mahboub NaCl disagrees with McCleskey NaCl at 25 C '
                    f'by more than 15% (ratios: {np.round(ratio, 3)}). '
                    'Check Conductivity_mScm units in the library (S/m vs mS/cm).')
    # (b) coarse magnitude check: MgSO4 near 25 C and 0.3-1.0 mol/kg
    #     must sit in the tens of mS/cm.
    mg = df[(df['Salt'] == 'MgSO4') & (df['Temperature_C'].between(20.0, 25.0)) &
            (df['Molality_molkg'].between(0.3, 1.0)) & (df['Pressure_MPa'] == 0.1)]
    if len(mg) >= 1:
        k = mg['Conductivity_mScm'].values
        if np.any((k < 10.0) | (k > 100.0)):
            raise ValueError(
                'UNIT GUARD: MgSO4 conductivity near 25 C and 0.3-1.0 mol/kg is outside '
                f'10-100 mS/cm (found {np.round(k, 2)}). Suspect a S/m vs mS/cm error.')
    print('Unit guard passed: Mahboub NaCl consistent with McCleskey NaCl at 25 C; '
          'MgSO4 magnitudes in the mS/cm window.')



def calculate_t_kcl(temp_C, molality):
    term1 = (9.04e-7 * (temp_C ** 2)) - (0.000235 * temp_C) + 0.4960
    sqrt_m = np.sqrt(molality)
    term2 = 0.0027 * (sqrt_m / (1.0 + 0.05 * sqrt_m))
    return term1 - term2



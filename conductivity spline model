def _clean_speciated_rows(d, tag):
    """Shared cleaning for any (salt, source) slice: reference pressure,
    valid molality, speciated (I_eff present) rows only. `tag` is just
    the log-message prefix. Does NOT deduplicate or average rows - that
    is fit_lambda_spline's job on the TRAINING side only; validation
    rows pass through here untouched, replicate-for-replicate."""
    d = d.copy()
    if d.empty:
        raise ValueError(f"No rows found for {tag}. Check CSV.")

    d = d[d['Pressure_MPa'] == REFERENCE_PRESSURE_MPA].copy()
    if d.empty:
        raise ValueError(f'{tag} has no rows at reference pressure.')

    d = d[~d['Molality_molkg'].isna()].copy()
    if d.empty:
        raise ValueError(f'{tag} has no usable rows left.')

    n_unspec = d['I_eff'].isna().sum()
    if n_unspec > 0:
        print(f'NOTE: {tag}: {n_unspec}/{len(d)} rows missing from {SPECIATION_FILE}. Dropped. '
              f'Rerun speciate_library.py if the library changed.')
        d = d[d['I_eff'].notna()].copy()
    if d.empty:
        raise ValueError(f'{tag} has no speciated rows. Run speciate_library.py.')

    d = d.rename(columns={'Molality_molkg': 'Molality', 'Temperature_C': 'Temperature',
                           'Conductivity_mScm': 'Conductivity'})
    d['temp_K'] = d['Temperature'] + 273.15
    d['I'] = d['I_eff']  # EFFECTIVE ionic strength everywhere downstream
    return d



def fit_lambda_spline(d, label, t_col='temp_K', I_col='I', lambda_col='Lambda', s=None):
    """Fit a bicubic IonSpline to (t_col, I_col) -> lambda_col.

    DUPLICATE HANDLING: multiple rows can legitimately share the same
    (t_col, I_col) condition - most commonly replicate measurements from
    a source that reports several runs per (Salt, T, molality), which all
    map onto the identical (T, I_eff) point once merged with the
    speciation table. Those rows are COLLAPSED BY AVERAGING lambda_col,
    not by keeping an arbitrary single row, so every replicate still
    contributes to the fit. The collapse (how many points, how many
    replicates, worst relative spread) is printed so silent data loss
    or a high-spread condition (e.g. instrument drift between replicate
    batches) is visible rather than hidden.
    """
    d = d.copy()
    n_before = len(d)

    other_cols = [c for c in d.columns if c not in (t_col, I_col, lambda_col)]
    grouped = d.groupby([t_col, I_col], as_index=False).agg(
        **{lambda_col: (lambda_col, 'mean')},
        _n_reps=(lambda_col, 'size'),
        _lambda_std=(lambda_col, 'std'),
    )
    if other_cols:
        firsts = d.groupby([t_col, I_col], as_index=False)[other_cols].first()
        grouped = grouped.merge(firsts, on=[t_col, I_col])
    d = grouped

    n_collapsed = int((d['_n_reps'] > 1).sum())
    if n_collapsed > 0:
        max_reps = int(d['_n_reps'].max())
        rel_spread = (d.loc[d['_n_reps'] > 1, '_lambda_std'] /
                      d.loc[d['_n_reps'] > 1, lambda_col].abs())
        worst_spread = float(rel_spread.max()) if len(rel_spread) else 0.0
        print(f"  {label}: collapsed {n_before} rows -> {len(d)} unique (T, I) points "
              f"({n_collapsed} points averaged over up to {max_reps} replicates, "
              f"worst relative std = {worst_spread:.2%}).")
    d = d.drop(columns=['_n_reps', '_lambda_std'])

    if len(d) < MIN_POINTS:
        raise ValueError(f"{label} has too few points ({len(d)}) for a usable bicubic spline surface.")

    spline = IonSpline(d[t_col].values, d[I_col].values, d[lambda_col].values, label, s=s)

    fitted = spline.ev(d[t_col].values, d[I_col].values)
    rel_rmse = np.sqrt(np.mean((d[lambda_col].values - fitted) ** 2)) / d[lambda_col].mean()
    print(f"{label}: interpolant built on {len(d)} points [{spline.method}], "
          f"s={spline.s_used:.3g}, training rel. RMSE={rel_rmse:.3e}, "
          f"T {spline.t_range[0]:.1f}-{spline.t_range[1]:.1f} K, "
          f"I {spline.I_range[0]:.4f}-{spline.I_range[1]:.4f} mol/kg")
    return spline, spline.t_range, spline.I_range, d


def subtract_ion_molar(source_df, salt_name, known_ion, model, new_ion_pretty_label=None):
    """Deconvolution step on FREE-ION molalities:
        kappa_salt = m_free_known * lambda_known + m_free_new * lambda_new
                     (+ pair conductivity, NEGLECTED in this pass)
    so  lambda_new = (kappa_salt - m_free_known * lambda_known) / m_free_new.
    Both lambdas are evaluated/indexed at EFFECTIVE ionic strength."""
    stoich = model.stoich_for(salt_name)
    if known_ion not in stoich:
        raise ValueError(f"{salt_name} stoichiometry {stoich} has no ion '{known_ion}'.")
    unknown_ions = [ion for ion in stoich if ion != known_ion]
    if len(unknown_ions) != 1:
        raise ValueError(f"subtract_ion_molar only supports two-ion salts; {salt_name} stoichiometry is {stoich}.")
    new_ion = unknown_ions[0]
    new_ion_label = new_ion_pretty_label or f"{new_ion} (from {salt_name})"

    ion_spline = model.ion(known_ion)

    I_vals = source_df['I'].values                          # effective I
    t_vals = source_df['temp_K'].values
    m_salt = source_df['Molality'].values
    m_free_known = source_df[ION_FREE_COL[known_ion]].values  # free-ion molality
    m_free_new = source_df[ION_FREE_COL[new_ion]].values      # free-ion molality

    lambda_known = ion_spline.ev_or_nan(t_vals, I_vals)
    in_hull = ~np.isnan(lambda_known)
    n_out = (~in_hull).sum()
    if n_out > 0:
        print(f"NOTE: {salt_name} -> {new_ion_label}: {n_out}/{len(source_df)} points fall outside "
              f"the {known_ion} spline's convex hull at solution I. Excluded.")

    kappa_salt = source_df['Conductivity'].values[in_hull]
    m_scaled = m_salt[in_hull]

    # PHASE 4: remove the conducting charged-pair contribution BEFORE the
    # residual, so the derived ion surface is not contaminated by it.
    kappa_pairs = np.zeros_like(kappa_salt)
    if PAIR_CONDUCTION and salt_name in SALT_PAIR_TERMS:
        cols = [c for c in SALT_PAIR_TERMS[salt_name] if c in source_df.columns]
        if cols:
            kappa_pairs = pair_kappa(source_df.iloc[in_hull], t_vals[in_hull],
                                      I_vals[in_hull], cols)
            frac = kappa_pairs / kappa_salt
            print(f"  {salt_name}: subtracting {', '.join(cols)} conduction "
                  f"(up to {100 * frac.max():.1f}% of kappa) before deconvolution.")

    kappa_residual = kappa_salt - kappa_pairs - (m_free_known[in_hull] * lambda_known[in_hull])
    lambda_new = kappa_residual / m_free_new[in_hull]

    t_kept = t_vals[in_hull]
    I_kept = I_vals[in_hull]
    m_kept = m_scaled

    pos = lambda_new > 0
    if (~pos).any():
        print(f"WARNING: {(~pos).sum()} {new_ion_label} points are non-positive. Dropped.")

    ion_df = pd.DataFrame({'temp_K': t_kept[pos], 'I': I_kept[pos], 'Molality': m_kept[pos], 'Lambda': lambda_new[pos]})
    spline, t_range, I_range, ion_df = fit_lambda_spline(ion_df, new_ion_label)
    model.add_ion(new_ion, spline)
    return spline, t_range, I_range, ion_df


